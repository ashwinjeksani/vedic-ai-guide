# Copy this file to .env and add a key for whichever provider(s) you want.
# The app works with either one; set both to switch between them in the UI.

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
